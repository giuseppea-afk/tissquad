{%- comment -%}
  Shipping badge — display under the Add to Cart button on the product page.
  Usage: {% render 'shipping-badge' %}
{%- endcomment -%}

<div class="shipping-badge">

  <!-- Row 1: delivery time -->
  <div class="shipping-badge__row shipping-badge__row--delivery">
    <svg class="shipping-badge__clock" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true">
      <path d="M256 0a256 256 0 1 1 0 512A256 256 0 1 1 256 0zM232 120l0 136c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.5 33.3-6.5s4.5-25.9-6.5-33.3L280 243.2 280 120c0-13.3-10.7-24-24-24s-24 10.7-24 24z"/>
    </svg>
    <span class="shipping-badge__delivery-text">Consegna in <strong>24 ore</strong></span>
  </div>

  <!-- Row 2: carrier logos -->
  <div class="shipping-badge__row shipping-badge__row--carrier">
    <span class="shipping-badge__carrier-label">Spedito da</span>

    <span class="shipping-badge__logo">
      <svg class="logo-tissquad" viewBox="0 0 215 50" xmlns="http://www.w3.org/2000/svg" aria-label="Tissquad" role="img">
        <path d="M27 7C21 11 11 16 0 20c7 2 14 2 18 5-4 5-10 10-18 16 8-3 16-6 21-11l2 9c2-6 3-12 2-18l4 16c2-5 5-10 3-15 5 3 12 7 18 10-6-6-13-12-18-18 6-2 13-2 18-5C42 13 33 8 27 7z" fill="#111"/>
        <text x="52" y="38" font-family="'Arial Black','Arial',sans-serif" font-size="25" font-weight="900" fill="#111" letter-spacing="1">TISSQUAD</text>
      </svg>
    </span>

    <span class="shipping-badge__separator">&#215;</span>

    <span class="shipping-badge__logo">
      <svg class="logo-amazon-shipping" viewBox="0 0 420 72" xmlns="http://www.w3.org/2000/svg" aria-label="Amazon Shipping" role="img">
        <text x="2" y="50" font-family="'Arial Rounded MT Bold','Arial',sans-serif" font-size="46" font-weight="900" fill="#232F3E">amazon</text>
        <path d="M6 61 Q67 80 128 61" stroke="#00A8E1" stroke-width="5" fill="none" stroke-linecap="round"/>
        <path d="M118 55 L132 62 L116 67 Z" fill="#00A8E1"/>
        <text x="148" y="50" font-family="'Arial Rounded MT Bold','Arial',sans-serif" font-size="46" font-weight="900" fill="#232F3E">shipping</text>
      </svg>
    </span>
  </div>

</div>
